{
  "name": "LaTeX Dev",
  "service": "latex",
  "image": "texlive/texlive:latest-full",
  "settings": {
    "latex-workshop.latex.outDir": "./out",
    "latex-workshop.latex.auxDir": "./aux"
  },
  "extensions": [
    "james-yu.latex-workshop",
    "Tyriar.luna-paint"
  ],
  "workspaceFolder": "/workdir",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workdir,type=bind"
  ],
}
