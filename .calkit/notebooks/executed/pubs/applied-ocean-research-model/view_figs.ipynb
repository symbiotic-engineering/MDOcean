   "source": [
    "import glob\n",
    "import fitz\n",
    "from IPython.display import Image, display\n",
    "\n",
    "pdf_files = sorted(glob.glob('figs/from-matlab/*.pdf'))\n",
    "\n",
    "for pdf_path in pdf_files:\n",
    "    print(pdf_path)\n",
    "    doc = fitz.open(pdf_path)\n",
    "    page = doc[0]\n",
    "    \n",
    "    im = page.get_pixmap()\n",
    "    display(Image(im.tobytes()))"
   ]
  }
